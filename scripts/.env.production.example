# Production DB credentials for sync-db.sh
# Copy this file to .env.production and fill in real values.
# NEVER commit .env.production to git.
#
# ── Supabase setup ────────────────────────────────────────────────────────────
# In Supabase dashboard → Settings → Database → Connection string
# Use the "URI" tab and copy the "Direct connection" URL (port 5432).
# Do NOT use the "Connection pooling" URL (port 6543) — pg_dump won't work with it.
#
# Option A — single URL (recommended for Supabase):
PROD_PG_URL="postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres"
#
# Option B — individual variables (comment out PROD_PG_URL above if using these):
# PROD_PG_HOST="db.[project-ref].supabase.co"
# PROD_PG_PORT="5432"
# PROD_PG_USER="postgres"
# PROD_PG_PASSWORD="your-db-password"
# PROD_PG_DATABASE="postgres"
