{
  "name": "@vvruspat/words-types",
  "version": "1.1.0",
  "license": "MIT",
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "dev": "tsc --project tsconfig.json --watch",
    "generate": "openapi-typescript ../../apps/api/openapi.yaml --output src/api.ts && npm run split",
    "split": "ts-node src/scripts/generate-aliases.ts",
    "lint": "biome lint src",
    "format": "biome check src --write --unsafe"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "dependencies": {
    "@nestjs/mapped-types": "*",
    "@nestjs/swagger": "^11.2.6"
  },
  "devDependencies": {
    "@repo/typescript-config": "*",
    "@types/node": "^25.5.0",
    "openapi-typescript": "^7.13.0",
    "ts-loader": "^9.5.4",
    "ts-node": "^10.9.2",
    "typescript": "5.9.3"
  }
}
